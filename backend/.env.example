# ── Jira Server / Data Center ────────────────────────────────────────────────
# URL base de tu instancia Jira (sin slash al final)
JIRA_BASE_URL=https://jira.tu-empresa.com

# Personal Access Token generado en Jira (Perfil → Manage account → Security → PAT)
JIRA_PAT=tu_personal_access_token_aqui

# Clave del proyecto Jira (ej: BACK, FRONT, GP)
JIRA_PROJECT_KEY=GP

# ── Confluence ───────────────────────────────────────────────────────────────
# URL base de Confluence (puede ser el mismo dominio que Jira)
CONFLUENCE_BASE_URL=https://confluence.tu-empresa.com

# Personal Access Token de Confluence (puede ser el mismo que el de Jira si es Data Center)
CONFLUENCE_PAT=tu_confluence_pat_aqui

# ID de la página de Confluence donde se publicará el reporte ejecutivo
CONFLUENCE_PAGE_ID=123456789

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# Orígenes permitidos para CORS (separados por coma, sin espacios)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Cache ────────────────────────────────────────────────────────────────────
# TTL del caché en memoria, en segundos (300 = 5 minutos)
CACHE_TTL=300

# ── AI Analysis (Google Gemini API) ──────────────────────────────────────────
# Key para el análisis inteligente de reportes diarios
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ── Cloudflare Tunnel (Optional) ─────────────────────────────────────────────
# Token generado en el dashboard de Cloudflare Zero Trust
CLOUDFLARE_TUNNEL_TOKEN=tu_cloudflare_tunnel_token_aqui
